    function formatSD(SD, limitdecimal) {
        var SDtext = SD.toFixed(1);

        if (SD > limitdecimal) {
            SDtext = " - ";
        } else if (SD === 0) {
            SDtext = SD.toFixed(0);
        } else if (SD < 0) {
            SDtext = '+' + Math.abs(SD).toFixed(1);
        } else {
            SDtext = SD.toFixed(1);
        }

        return SDtext;
